{
  "manifest_version": 3,
  "name": "FreeRide",
  "version": "0.2.0",
  "description": "Claude Code's gateway to web AI assistants",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
